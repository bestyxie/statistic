{
  "name": "statistic",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "./dev.sh",
    "dev:api": "pnpm --filter @statistic/api dev",
    "dev:web": "pnpm --filter @statistic/web dev",
    "build": "pnpm --filter @statistic/web build",
    "lint": "eslint .",
    "test": "pnpm --filter @statistic/api test",
    "db:init": "pnpm --filter @statistic/api db:init"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "typescript-eslint": "^8.62.1"
  }
}
