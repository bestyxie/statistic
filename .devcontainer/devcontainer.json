// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/typescript-node
{
	"name": "Node.js & TypeScript",
	// Or use a Dockerfile or Docker Compose file. More info: https://containers.dev/guide/dockerfile
	"image": "mcr.microsoft.com/devcontainers/typescript-node:4-22-bookworm",
	"runArgs": [
		"--name",
		"statistic"
	],
	"features": {
		"ghcr.io/warrenbuckley/codespace-features/sqlite:1": {}
	},
	// Use 'postCreateCommand' to run commands after the container is created.
	// "postStartCommand": "mkdir -p ~/.claude && cp /mnt/claude-config/settings.json ~/.claude/settings.json",
	"postCreateCommand": "npm install -g @anthropic-ai/claude-code && mkdir -p ~/.config/pnpm && printf 'storeDir: /var/lib/pnpm-store\\n' > ~/.config/pnpm/config.yaml",
	"mounts": [
		"source=claude-code-config-${devcontainerId},target=/home/root/.claude,type=volume",
		"source=claude-code-node-modules-${devcontainerId},target=${containerWorkspaceFolder}/node_modules,type=volume",
		"source=claude-code-pnpm-store,target=/var/lib/pnpm-store,type=volume"
	]
	// Configure tool-specific properties.
	// "customizations": {},
	// Uncomment to connect as root instead. More info: https://aka.ms/dev-containers-non-root.
	// "remoteUser": "root"
}